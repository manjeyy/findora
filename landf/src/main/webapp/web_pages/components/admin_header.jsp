<header
  class="sticky top-0 z-40 bg-slate-50 flex justify-between items-center px-8 py-4 w-full"
>
  <div class="flex items-center gap-6">
    <div class="relative">
      <span
        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[18px]"
        >search</span
      >
      <input
        class="pl-10 pr-4 py-2 bg-slate-100 border-none rounded-full text-sm focus:ring-2 focus:ring-teal-600 w-80"
        placeholder="Search institutional data..."
        type="text"
      />
    </div>
  </div>
  <div class="flex items-center gap-4">
    <button
      class="p-2 text-slate-500 hover:bg-slate-200/50 rounded-full transition-colors relative"
    >
      <span class="material-symbols-outlined">notifications</span>
      <span
        class="absolute top-2 right-2 w-2 h-2 bg-orange-500 rounded-full"
      ></span>
    </button>
    <div class="flex items-center gap-3 pl-4 border-l border-slate-200">
      <div class="text-right">
        <p class="text-sm font-bold text-teal-900">Administrator</p>
        <p class="text-[10px] text-slate-500 uppercase">Primary Access</p>
      </div>
      <div
        class="w-10 h-10 rounded-full bg-teal-800 flex items-center justify-center text-white"
      >
        <span class="material-symbols-outlined">person</span>
      </div>
    </div>
  </div>
</header>
